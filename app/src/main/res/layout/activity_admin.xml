<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    >

    <Button
        android:id="@+id/btnBackToShop"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Wróć do sklepu" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Dodaj nowe buty:"
        android:textStyle="bold"
        android:layout_marginTop="10dp"/>

    <EditText android:id="@+id/etBrand" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Marka (np. Nike)"/>
    <EditText android:id="@+id/etModel" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Model (np. Dunk)"/>
    <EditText android:id="@+id/etYear" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Rok" android:inputType="number"/>
    <EditText android:id="@+id/etPrice" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Cena" android:inputType="number"/>
    <EditText android:id="@+id/etImage" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Link do zdjęcia"/>

    <Button
        android:id="@+id/btnAddShoe"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="DODAJ DO BAZY"
        android:layout_marginTop="10dp"/>

    <androidx.appcompat.widget.SearchView
        android:id="@+id/searchAdminView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="8dp"
        android:background="@android:color/white"
        android:elevation="2dp"
        app:iconifiedByDefault="false"
        app:queryHint="Szukaj po modelu..." />

    <GridView
        android:id="@+id/shoesAdminGridView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:numColumns="2"
        android:horizontalSpacing="8dp"
        android:verticalSpacing="8dp"
        android:padding="8dp"
        android:clipToPadding="false" />
</LinearLayout>